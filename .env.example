# LiveKit Credentials (Get from https://cloud.livekit.io)
LIVEKIT_URL=wss://<your-livekit-project>.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Groq AI API Key (Needed if LLM_PROVIDER = "groq")
GROQ_API_KEY=your_groq_api_key

# Sarvam AI API Key (Needed if STT_PROVIDER or TTS_PROVIDER = "sarvam")
SARVAM_API_KEY=your_sarvam_api_key

# OpenAI API Key (Needed if LLM_PROVIDER or TTS_PROVIDER = "openai")
OPENAI_API_KEY=your_openai_api_key

# Deepgram API Key (Needed if TTS_PROVIDER = "deepgram")
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini API Key (Needed if LLM_PROVIDER = "gemini")
GOOGLE_API_KEY=your_google_api_key

# Google Cloud Credentials (Optional - only when STT_PROVIDER = "google")
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Supabase Configuration for Ticketing System (Optional)
SUPABASE_URL=https://your-supabase-project.supabase.co/rest/v1
SUPABASE_API_KEY=your_supabase_api_key

# Mem0 Configuration for Persistent Memory
MEM0_API_KEY=your_mem0_api_key

# Memory Subsystem Options (Optional - defaults are set)
MEMORY_ENABLED=true
MEMORY_PROVIDER=mem0
MEMORY_STORAGE_PATH=~/.friday/memories
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_TTL=300
MEMORY_MAX_MEMORIES=100
MEMORY_PREFETCH_LIMIT=10
MEMORY_RANKING_LIMIT=5
MEMORY_LOGGING_ENABLED=true
